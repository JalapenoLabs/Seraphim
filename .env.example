# =============================================================================
# Seraphim environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the secrets. Each deployment (e.g. your
# JalapenoLabs laptop vs. your MooreslabAI work laptop) gets its own `.env`.
# Never commit the real `.env`.
# =============================================================================

# --- Database -----------------------------------------------------------------
# These defaults are fine for a single-host self-hosted install. Change the
# password before exposing anything beyond localhost.
POSTGRES_USER=seraphim_keeper
POSTGRES_PASSWORD=Gx7pQ2vR9mZ4wL_chooseyourown
POSTGRES_DB=seraphim

# Connection string the API uses to reach Postgres over the compose network.
# Host is the postgres service name; keep it in sync with the three values above.
DATABASE_URL=postgres://seraphim_keeper:Gx7pQ2vR9mZ4wL_chooseyourown@postgres:5432/seraphim

# --- Ports (host-side) --------------------------------------------------------
# Deliberately non-standard to avoid colliding with other local dev servers.
API_PORT=27182
FRONTEND_PORT=31415

# --- Claude (subscription auth, no API key) -----------------------------------
# The Claude OAuth token (from `claude setup-token`) and the GitHub token are NOT
# kept here. They live in the database and are entered in the Settings UI, so a
# host worm scanning for .env files can't harvest them. See README.

# Absolute path to the host's ~/.ssh folder. Mounted read-only into the workspace
# so the agent can clone git@github.com SSH repos (and your ~/.claude config repo)
# with your keys. `~` is NOT expanded reliably, so give a full path:
#   Linux:    /home/youruser/.ssh
#   Windows:  C:/Users/youruser/.ssh
SSH_HOME=/home/youruser/.ssh

# The agent's ~/.claude config (AGENTS.md, docs, manuals, skills) is provisioned
# by cloning a git repo you set in the UI (Settings -> Config repo), not mounted.

# Model the agent runs as. Opus 4.8 (1M context) is the default for long-lived
# single-threaded sessions.
CLAUDE_MODEL=claude-opus-4-8[1m]

# --- Tailscale ----------------------------------------------------------------
# Auth key from https://login.tailscale.com/admin/settings/keys (reusable +
# ephemeral recommended for a container). Leave blank to skip Tailscale and use
# the raw host ports instead.
TS_AUTHKEY=
# MagicDNS hostname this node registers as (https://<TS_HOSTNAME>.<tailnet>.ts.net).
TS_HOSTNAME=seraphim

# --- Docker socket ------------------------------------------------------------
# The API and workspace containers talk to the host Docker daemon through this
# socket. The in-container path is the same on Linux and Docker Desktop/Windows.
DOCKER_SOCKET=/var/run/docker.sock

# --- Self-update --------------------------------------------------------------
# The in-app "Update" button (Settings -> Updates) launches a short-lived updater
# container that bind-mounts this HOST path to the cloned repo and runs
# `git pull` + `docker compose up -d --build`. scripts/start.sh fills this in
# automatically (the repo root), so you only need to set it when starting the
# stack some other way, or when the auto-detected path isn't Docker-mountable.
#   Linux:    /home/youruser/Seraphim
#   Windows:  C:/Users/youruser/Seraphim
# Leave blank to disable the in-app update (the version check still works).
HOST_REPO_DIR=

# --- Org profile bootstrap ----------------------------------------------------
# Seeds the initial environment profile on first run (editable later in the UI).
# Examples: JalapenoLabs, MooreslabAI.
ORG_NAME=JalapenoLabs
